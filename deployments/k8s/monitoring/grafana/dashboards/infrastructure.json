      "targets": [
        {
          "expr": "sum(container_fs_usage_bytes{namespace=\"auction-system\", container!=\"\", pod=~\"$pod\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Disk I/O Rate per Pod",
      "type": "timeseries",
      "datasource": "Prometheus",
