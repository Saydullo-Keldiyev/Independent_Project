    {
      "title": "Pod Restarts",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"auction-system\", pod=~\"$pod\"}[10m])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["auction-system", "infrastructure"],
  "templating": {
    "list": [
      {
        "name": "pod",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(container_cpu_usage_seconds_total{namespace=\"auction-system\", container!=\"\"}, pod)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "time": {
