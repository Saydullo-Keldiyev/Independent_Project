  },
  "description": "Infrastructure metrics: CPU, memory, disk, and network utilization per pod",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage per Pod",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * sum(rate(container_cpu_usage_seconds_total{namespace=\"auction-system\", container!=\"\", pod=~\"$pod\"}[5m])) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"auction-system\", resource=\"cpu\", pod=~\"$pod\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage per Pod",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 419430400 },
              { "color": "red", "value": 536870912 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"auction-system\", container!=\"\", pod=~\"$pod\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage % of Limit per Pod",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "No Data",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"auction-system\", container!=\"\", pod=~\"$pod\"}) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"auction-system\", resource=\"memory\", pod=~\"$pod\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "CPU Usage % of Limit per Pod",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "No Data",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"auction-system\", container!=\"\", pod=~\"$pod\"}[5m])) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"auction-system\", resource=\"cpu\", pod=~\"$pod\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Disk Usage per Pod (Filesystem)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "noValue": "No Data"
        }
