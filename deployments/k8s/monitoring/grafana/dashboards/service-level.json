{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Service-level metrics: request rate, error rate, latency percentiles, and resource saturation",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate by Service",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"auction-system\"}[5m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Error Rate by Service (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"auction-system\", status=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total{namespace=\"auction-system\"}[5m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latency P50 by Service",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"auction-system\"}[5m])) by (service, le))",
          "legendFormat": "{{service}} P50",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latency P95 by Service",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"auction-system\"}[5m])) by (service, le))",
          "legendFormat": "{{service}} P95",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latency P99 by Service",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"auction-system\"}[5m])) by (service, le))",
          "legendFormat": "{{service}} P99",
          "refId": "A"
        }
      ]
    },
    {
      "title": "CPU Saturation (>80% of limit)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "No Data",
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"auction-system\", container!=\"\"}[5m])) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"auction-system\", resource=\"cpu\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Saturation (>80% of limit)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "No Data",
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"auction-system\", container!=\"\"}) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"auction-system\", resource=\"memory\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Connection Pool Saturation",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "db_pool_active_connections{namespace=\"auction-system\"} / db_pool_max_connections{namespace=\"auction-system\"}",
          "legendFormat": "{{service}} DB Pool",
          "refId": "A"
        },
        {
          "expr": "redis_pool_active_connections{namespace=\"auction-system\"} / redis_pool_max_connections{namespace=\"auction-system\"}",
          "legendFormat": "{{service}} Redis Pool",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Goroutine Count by Service",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "go_goroutines{namespace=\"auction-system\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["auction-system", "service-level"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_requests_total{namespace=\"auction-system\"}, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m", "30m"],
    "time_options": ["15m", "30m", "1h", "6h", "12h", "24h", "7d", "15d"]
  },
  "timezone": "browser",
  "title": "Auction System - Service Level",
  "uid": "auction-service-level",
  "version": 1
}
