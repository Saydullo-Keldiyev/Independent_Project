{
  "dashboard": {
    "title": "Bid Service Dashboard",
    "uid": "bid-service",
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "title": "Bid Requests/sec",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          { "expr": "rate(bid_requests_total[1m])", "legendFormat": "{{status}}" }
        ]
      },
      {
        "title": "Bid Latency (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          { "expr": "histogram_quantile(0.95, rate(bid_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
          { "expr": "histogram_quantile(0.99, rate(bid_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
        ]
      },
      {
        "title": "WebSocket Connections",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [
          { "expr": "bid_service_websocket_connections_active", "legendFormat": "active" }
        ]
      },
      {
        "title": "WebSocket Messages/sec",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          { "expr": "rate(bid_service_websocket_messages_total[1m])", "legendFormat": "{{auction_id}}" }
        ]
      },
      {
        "title": "Redis Operations",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          { "expr": "rate(redis_operation_duration_seconds_sum[5m]) / rate(redis_operation_duration_seconds_count[5m])", "legendFormat": "avg latency {{operation}}" }
        ]
      },
      {
        "title": "Kafka Publish Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "targets": [
          { "expr": "rate(kafka_publish_total[1m])", "legendFormat": "{{event_type}} {{status}}" }
        ]
      },
      {
        "title": "DB Query Duration",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "targets": [
          { "expr": "histogram_quantile(0.95, rate(db_query_duration_seconds_bucket[5m]))", "legendFormat": "{{query}}" }
        ]
      },
      {
        "title": "Lock Acquire Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
        "targets": [
          { "expr": "rate(lock_acquire_total[1m])", "legendFormat": "{{status}}" }
        ]
      }
    ]
  }
}
