{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Business metrics: active auctions, bids per minute, transaction volume, and WebSocket connections",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Auctions",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "auction_active_count{namespace=\"auction-system\"}",
          "legendFormat": "Active Auctions",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Bids per Minute",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "yellow", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(bid_placed_total{namespace=\"auction-system\"}[1m])) * 60",
          "legendFormat": "Bids/min",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Transaction Volume (Total)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(wallet_transaction_volume_total{namespace=\"auction-system\"})",
          "legendFormat": "Total Volume",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Active WebSocket Connections",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7000 },
              { "color": "red", "value": 9000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(bid_service_websocket_connections_active{namespace=\"auction-system\"})",
          "legendFormat": "WebSocket Connections",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Active Auctions Over Time",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "auction_active_count{namespace=\"auction-system\"}",
          "legendFormat": "Active Auctions",
          "refId": "A"
        },
        {
          "expr": "auction_pending_count{namespace=\"auction-system\"}",
          "legendFormat": "Pending Auctions",
          "refId": "B"
        },
        {
          "expr": "auction_completed_count{namespace=\"auction-system\"}",
          "legendFormat": "Completed Auctions",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Bids per Minute Over Time",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(bid_placed_total{namespace=\"auction-system\"}[1m])) * 60",
          "legendFormat": "Bids/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(bid_rejected_total{namespace=\"auction-system\"}[1m])) * 60",
          "legendFormat": "Rejected Bids/min",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Transaction Volume Over Time",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(wallet_transaction_volume_total{namespace=\"auction-system\"}[5m])) * 300",
          "legendFormat": "Volume (5min rate)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Transaction Count by Type",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(wallet_transactions_total{namespace=\"auction-system\"}[5m])) by (operation_type) * 300",
          "legendFormat": "{{operation_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "WebSocket Connections per Pod",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "bid_service_websocket_connections_active{namespace=\"auction-system\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Auction Settlement Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "No Data"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(saga_completed_total{namespace=\"auction-system\", saga_type=\"settlement\"}[5m]))",
          "legendFormat": "Settlements/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(saga_failed_total{namespace=\"auction-system\", saga_type=\"settlement\"}[5m]))",
          "legendFormat": "Failed Settlements/s",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["auction-system", "business"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m", "30m"],
    "time_options": ["15m", "30m", "1h", "6h", "12h", "24h", "7d", "15d"]
  },
  "timezone": "browser",
  "title": "Auction System - Business Metrics",
  "uid": "auction-business",
  "version": 1
}
